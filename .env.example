# Database
DATABASE_URL="postgresql://username:password@localhost:5432/aesthetics_leads_db"

# API Keys
COMPANIES_HOUSE_API_KEY="your_companies_house_api_key"
APIFY_TOKEN="your_apify_token"
APIFY_FB_ADS_ACTOR="your_facebook_ads_actor_id"
META_ADLIB_TOKEN="your_meta_ad_library_token"
META_GRAPH_VERSION="v25.0"

# AI Providers (with automatic fallback)
ANTHROPIC_API_KEY="your_anthropic_api_key"
GEMINI_API_KEY="your_gemini_api_key"
AI_PRIMARY_PROVIDER="anthropic"  # Options: "anthropic" or "gemini"
AI_TIMEOUT_MS="30000"

# Email
RESEND_API_KEY="your_resend_api_key"
RESEND_SENDER_DOMAIN="playbookmpr.co.uk"

# Server Configuration
NODE_ENV="development"
PORT="3000"
DASHBOARD_PORT="3001"
BASE_URL="http://localhost:3000"

# Cost Control
MAX_DAILY_TOKENS="50000"
SCORING_BATCH_SIZE="10"
